---
import { Github, ExternalLink, Info } from 'lucide-astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Lang } from '~/i18n/utils';

interface Props {
  name: string;
  description: string;
  icon: string;
  background: string;
  url?: string;
  repo?: string;
  hasPage?: boolean;
  slug?: string;
  tags?: string[];
  series?: string;
  lang?: Lang;
}

const { name, description, icon, background, url, repo, slug, tags = [], series, lang = 'en' } = Astro.props;
---

<div class="card bg-base-100 shadow-xl overflow-hidden hover:-translate-y-2 transition-transform duration-300">
  <div class="relative aspect-video overflow-hidden group">
    <a href={getRelativeLocaleUrl(lang, `products/${slug}`)}>
      <img src={background} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" alt={name} />
    </a>
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-90"></div>

    <div class="absolute top-4 right-4 flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
      {repo && (
        <a href={repo} target="_blank" class="btn btn-circle btn-sm bg-white/80 hover:bg-white">
          <Github class="w-4 h-4" />
        </a>
      )}
      {url && (
        <a href={url} target="_blank" class="btn btn-circle btn-sm bg-white/80 hover:bg-white">
          <ExternalLink class="w-4 h-4" />
        </a>
      )}
      <a href={getRelativeLocaleUrl(lang, `products/${slug}`)} class="btn btn-circle btn-sm bg-white/80 hover:bg-white">
        <Info class="w-4 h-4" />
      </a>
    </div>

    <a href={getRelativeLocaleUrl(lang, `products/${slug}`)} class="absolute bottom-0 left-0 right-0 p-6">
      <div class="flex items-center gap-3 mb-2">
        <img src={icon} class="w-10 h-10 rounded-lg shadow-sm" alt={name} />
        <h3 class="text-xl font-bold text-white">{name}</h3>
      </div>
      <p class="text-gray-200 text-sm line-clamp-2">{description}</p>
    </a>
  </div>

  {(tags.length > 0 || series) && (
    <div class="p-4 border-t border-base-200">
      <div class="flex flex-wrap gap-1">
        {series && (
          <a href={`${getRelativeLocaleUrl(lang, 'products')}?series=${encodeURIComponent(series)}`} class="badge badge-sm badge-primary hover:badge-secondary transition-colors">
            {series}
          </a>
        )}
        {tags.slice(0, 4).map(tag => (
          <a href={`${getRelativeLocaleUrl(lang, 'products')}?tag=${encodeURIComponent(tag)}`} class="badge badge-sm badge-outline hover:badge-primary transition-colors">
            {tag}
          </a>
        ))}
        {tags.length > 4 && (
          <span class="badge badge-sm badge-ghost">+{tags.length - 4}</span>
        )}
      </div>
    </div>
  )}
</div>
