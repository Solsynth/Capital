---
import { Code, Server, Gamepad2, Users } from 'lucide-astro';

const features = [
  {
    icon: Code,
    title: "Developer First",
    description: "Native syntax highlighting, code snippet sharing, and seamless integration with your favorite dev tools."
  },
  {
    icon: Server,
    title: "OpenAPI",
    description: "Fully documented API, transparent rate limiting and risk control. Great for building your own apps!"
  },
  {
    icon: Gamepad2,
    title: "ACG Culture",
    description: "A dedicated space for Anime, Comic, and Game enthusiasts. Share your art, reviews, and passion."
  },
  {
    icon: Users,
    title: "Friendly Community",
    description: "Join a vibrant community of like-minded individuals. Share knowledge, ask questions, and connect."
  }
];
---

<section class="py-16 px-4">
  <div class="container mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Why Choose Us</h2>
      <p class="text-lg md:text-xl opacity-70 max-w-2xl mx-auto">
        We build products with developers and enthusiasts in mind.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((feature, i) => (
        <div class="card bg-base-200 hover:bg-base-300 transition-colors p-6 text-center group hover:-translate-y-2 duration-300">
          <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-4 group-hover:bg-primary/20 transition-colors">
            <feature.icon class="w-7 h-7 text-primary" />
          </div>
          <h3 class="text-lg font-bold mb-2">{feature.title}</h3>
          <p class="text-sm opacity-70">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
