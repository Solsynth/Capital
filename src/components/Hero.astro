---
import { ChevronDown } from 'lucide-astro';
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const strings = lang === 'zh' 
  ? ['制作软件', '制作硬件', '创造体验', '书写故事', '是 Solsynth']
  : ['make software', 'make hardware', 'craft experiences', 'write stories', 'are Solsynth'];

const subtitle = lang === 'zh'
  ? '我们是一群志同道合的朋友，致力于打造软件、硬件和一切有趣的事物。'
  : 'We are a group of friends that make software, hardware and any stuff that is interesting.';
---

<section class="min-h-[80vh] flex flex-col items-center justify-center text-center relative px-4">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary/20 rounded-full blur-[120px] -z-10 pointer-events-none max-md:w-[300px] max-md:h-[300px]"></div>

  <div class="container mx-auto max-w-4xl">
    <img src="/favicon.png" class="w-24 md:w-32 mb-8 animate-float mx-auto" alt="Solsynth" />
    
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-6 tracking-tight">
      We <span id="typed-text" class="text-primary"></span>
    </h1>
    
    <p class="text-lg md:text-xl lg:text-2xl opacity-80 max-w-2xl mx-auto mb-10">
      {subtitle}
    </p>
    
    <div class="flex gap-4 flex-wrap justify-center">
      <a href={`/${lang === 'zh' ? 'zh/' : ''}products`} class="btn btn-primary btn-lg rounded-full px-6 md:px-8 text-lg font-bold shadow-lg shadow-primary/30 hover:shadow-primary/50 transition-shadow">
        {t('nav.products')}
      </a>
      <a href={`/${lang === 'zh' ? 'zh/' : ''}about`} class="btn btn-lg rounded-full px-6 md:px-8 text-lg">
        {t('nav.about')}
      </a>
    </div>
  </div>

  <div class="absolute bottom-10 animate-bounce">
    <ChevronDown class="w-8 h-8 opacity-50" />
  </div>
</section>

<script define:vars={{ strings }}>
  const typedElement = document.getElementById('typed-text');
  let index = 0;
  let charIndex = 0;
  let isDeleting = false;
  let timeout: number;

  function type() {
    if (!typedElement) return;

    const current = strings[index];
    
    if (isDeleting) {
      typedElement.textContent = current.substring(0, charIndex - 1);
      charIndex--;
    } else {
      typedElement.textContent = current.substring(0, charIndex + 1);
      charIndex++;
    }

    let typeSpeed = isDeleting ? 30 : 50;

    if (!isDeleting && charIndex === current.length) {
      typeSpeed = 1500;
      isDeleting = true;
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      index = (index + 1) % strings.length;
      typeSpeed = 300;
    }

    timeout = window.setTimeout(type, typeSpeed);
  }

  type();
</script>

<style>
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
    100% { transform: translateY(0px); }
  }
</style>
