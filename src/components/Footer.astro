---
import { getLangFromUrl, useTranslations, type Lang } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const prefix = lang === 'zh' ? '/zh' : '';
---

<footer class="footer bg-base-200 text-base-content p-8 md:p-10">
  <div class="container mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
      <aside class="col-span-1 sm:col-span-2 md:col-span-1">
        <img src="/favicon.png" alt="Solsynth" class="w-10 md:w-12" />
        <div class="mt-2">
          <h3 class="font-bold text-lg">Solsynth</h3>
          <p class="text-sm opacity-70">{t('footer.tagline')}</p>
        </div>
      </aside>
      <nav>
        <h6 class="footer-title">{t('footer.products')}</h6>
        <a href="https://solian.app" target="_blank" class="link link-hover block text-sm">Solar Network</a>
        <a href={`${prefix}/products`} class="link link-hover block text-sm">{t('footer.catalog')}</a>
      </nav>
      <nav>
        <h6 class="footer-title">{t('footer.company')}</h6>
        <a href={`${prefix}/about`} class="link link-hover block text-sm">{t('footer.aboutUs')}</a>
        <a href="https://github.com/Solsynth" target="_blank" class="link link-hover block text-sm">{t('footer.github')}</a>
      </nav>
      <nav>
        <h6 class="footer-title">{t('footer.legal')}</h6>
        <a href={`${prefix}/legal/user-agreement`} class="link link-hover block text-sm">{t('footer.termsOfService')}</a>
        <a href={`${prefix}/legal/privacy-policy`} class="link link-hover block text-sm">{t('footer.privacyPolicy')}</a>
        <a href={`${prefix}/legal/refund-policy`} class="link link-hover block text-sm">{t('footer.refundPolicy')}</a>
        <a href={`${prefix}/legal/solar-network-dev`} class="link link-hover block text-sm">{t('footer.developerAgreement')}</a>
        <a href={`${prefix}/legal`} class="link link-hover block text-sm">{t('nav.legalAll')}</a>
      </nav>
    </div>
  </div>
</footer>
