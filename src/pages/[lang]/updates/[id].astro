---
import Layout from '../../../layouts/Layout.astro';
import { getPostById, formatDate, getAttachmentUrl } from '../../../utils/api';
import { ArrowLeft, Eye, MessageCircle, Heart, ArrowRight } from 'lucide-astro';
import { marked } from 'marked';
import { getLangFromUrl, useTranslations, type Lang } from '../../../i18n/utils';

export const prerender = false;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const prefix = lang === 'zh' ? '/zh' : '';
const { id } = Astro.params;

if (!id) {
  return Astro.redirect(`${prefix}/updates`);
}

const post = await getPostById(id);

if (!post) {
  return Astro.redirect(`${prefix}/updates`);
}

function getDisplayTitle(post: { title: string; content: string }): string {
  if (post.title && post.title.trim()) return post.title;
  const firstLine = post.content?.split('\n')[0]?.trim() || '';
  return firstLine.length > 50 ? firstLine.substring(0, 50) + '...' : firstLine || 'View Post';
}

const displayTitle = getDisplayTitle(post);
const contentHtml = post.content ? marked.parse(post.content) : '';
---

<Layout title={displayTitle}>
  <div class="container mx-auto px-8 py-16 max-w-4xl">
    <div class="mb-8 -mx-4">
      <a href={`${prefix}/updates`} class="btn btn-ghost btn-sm gap-1">
        <ArrowLeft class="w-4 h-4" />
        {t('updates.backToUpdates')}
      </a>
    </div>

    <article>
      <header class="mb-8">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">{displayTitle}</h1>
        <div class="flex flex-wrap items-center gap-4 text-sm opacity-70">
          <div class="flex items-center gap-2">
            {post.publisher?.picture && (
              <img 
                src={getAttachmentUrl(post.publisher.picture.id)}
                alt={post.publisher.nick}
                class="w-6 h-6 rounded-full"
              />
            )}
            <span>{post.publisher?.nick || 'Unknown'}</span>
          </div>
          <span>{formatDate(post.published_at)}</span>
          {post.edited_at && (
            <span class="italic">({lang === 'zh' ? '已编辑' : 'edited'})</span>
          )}
        </div>
      </header>

      {post.attachments.length > 0 && (
        <div class="mb-8">
          {post.attachments.length === 1 ? (
            <div class="rounded-xl overflow-hidden">
              <img 
                src={getAttachmentUrl(post.attachments[0].id)}
                alt={post.attachments[0].name}
                class="w-full max-h-[500px] object-contain bg-base-200"
              />
            </div>
          ) : (
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
              {post.attachments.map((attachment) => (
                <div class="rounded-xl overflow-hidden bg-base-200">
                  <img 
                    src={getAttachmentUrl(attachment.id)}
                    alt={attachment.name}
                    class="w-full aspect-video object-cover"
                  />
                </div>
              ))}
            </div>
          )}
        </div>
      )}

      <div class="prose prose-lg max-w-none mb-12" set:html={contentHtml} />

      <footer class="pt-2">
        <div class="flex flex-wrap items-center gap-6 text-sm opacity-70">
          <div class="flex items-center gap-2">
            <Eye class="w-4 h-4" />
            <span>{post.views_unique} {t('updates.uniqueViews')}</span>
          </div>
          <div class="flex items-center gap-2">
            <MessageCircle class="w-4 h-4" />
            <span>{post.replies_count} {t('updates.replies')}</span>
          </div>
          {Object.keys(post.reactions_count).length > 0 && (
            <div class="flex items-center gap-2">
              <Heart class="w-4 h-4" />
              <span>{Object.values(post.reactions_count).reduce((a, b) => a + b, 0)}</span>
            </div>
          )}
        </div>
      </footer>
    </article>

    <div class="mt-12 pt-4">
      <a 
        href={`https://solian.app/posts/${post.id}`}
        target="_blank"
        class="btn btn-outline btn-sm gap-2"
      >
        {t('updates.discussion')}
        <ArrowRight class="w-4 h-4" />
      </a>
    </div>
  </div>
</Layout>
