---
import Layout from '~/layouts/Layout.astro';
import { Github, ExternalLink, Bug, ArrowLeft, Tag, Folder, MessageSquare, FileText, Rss, Users, CreditCard, Globe, Sticker, Code, Heart, Sparkles, Zap, Shield, Smartphone, Monitor, Bell, Calendar, Wallet, Image, CheckCircle } from 'lucide-astro';
import { getLangFromUrl } from '~/i18n/utils';

const lang = getLangFromUrl(Astro.url);
---

<Layout title="Solar Network" description={lang === 'zh' ? '一个宁静的社交网络，让表达自我与连接他人变得简单而纯粹。' : 'A serene social network that makes self-expression and connecting with others simple and pure.'} lang={lang}>
  <div class="relative h-[60vh] min-h-120 overflow-hidden">
    <img src="/solar-network/screenshot.png" class="w-full h-full object-cover" alt="Solar Network" />
    <div class="absolute inset-0 bg-gradient-to-t from-base-100 via-base-100/60 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary/20 via-transparent to-secondary/20"></div>
    
    <div class="absolute bottom-0 left-0 right-0 p-8">
      <div class="container mx-auto flex flex-col md:flex-row items-end gap-6">
        <img src="/solar-network/icon.png" class="w-28 h-28 rounded-2xl shadow-2xl" alt="Solar Network" />
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-2">
            <h1 class="text-4xl md:text-4xl font-bold">Solar Network</h1>
          </div>
          <p class="text-xl opacity-90 mb-4">一个宁静的社交网络，让表达自我与连接他人变得简单而纯粹。</p>
          <div class="flex flex-wrap gap-2 mt-3">
            <a href="/zh/products?series=Solar%20Network" class="badge badge-primary badge-sm">
              <Folder class="w-3 h-3 mr-1" />
              Solar Network
            </a>
            <a href="/zh/products?tag=Social%20Network" class="badge badge-outline badge-sm hover:badge-primary transition-colors">
              <Tag class="w-3 h-3 mr-1" />
              Social Network
            </a>
            <a href="/zh/products?tag=Community" class="badge badge-outline badge-sm hover:badge-primary transition-colors">
              <Tag class="w-3 h-3 mr-1" />
              Community
            </a>
            <a href="/zh/products?tag=ACG" class="badge badge-outline badge-sm hover:badge-primary transition-colors">
              <Tag class="w-3 h-3 mr-1" />
              ACG
            </a>
            <span class="badge badge-outline badge-sm">
              <Globe class="w-3 h-3 mr-1" />
              Fediverse
            </span>
          </div>
        </div>
        <div class="flex gap-3 flex-wrap">
          <a href="https://web.solian.app" target="_blank" class="btn btn-primary btn-lg rounded-full hover:scale-105 transition-transform">
            <Sparkles class="w-5 h-5" />
            立即体验
          </a>
          <a href="https://github.com/Solsynth/Solian" target="_blank" class="btn btn-outline btn-lg rounded-full hover:scale-105 transition-transform">
            <Github class="w-5 h-5" />
            GitHub
          </a>
        </div>
      </div>
    </div>
    
    <div class="absolute top-20 left-10 opacity-20">
      <Sparkles class="w-16 h-16 text-primary" />
    </div>
    <div class="absolute top-40 right-20 opacity-20">
      <Heart class="w-12 h-12 text-secondary" />
    </div>
  </div>

  <div class="container mx-auto px-4 py-16">
    <section class="mb-20">
      <div class="text-center mb-12">
        <span class="badge badge-primary badge-outline mb-4">关于</span>
        <h2 class="text-4xl font-bold mb-4">关于 Solar Network</h2>
        <p class="text-lg opacity-70 max-w-3xl mx-auto">
          Solian（又名 Solar Network）是一个社交平台，旨在帮助你自由表达自我并与他人建立联系。我们并不打算取代任何主流平台——只是为你提供另一个宁静和谐的社区选择。
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-8 shadow-lg hover:shadow-xl">
          <div class="w-16 h-16 rounded-2xl bg-primary/20 flex items-center justify-center mb-4">
            <Heart class="w-8 h-8 text-primary" />
          </div>
          <h3 class="text-xl font-bold mb-2">宁静和谐</h3>
          <p class="opacity-80">一个远离喧嚣的社交空间，让你能够专注于真正重要的东西——与志同道合的人建立联系。在这里，你可以安静地分享自己的生活，无需担心噪音和信息过载。</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-8 shadow-lg hover:shadow-xl">
          <div class="w-16 h-16 rounded-2xl bg-secondary/20 flex items-center justify-center mb-4">
            <Code class="w-8 h-8 text-secondary" />
          </div>
          <h3 class="text-xl font-bold mb-2">开发者友好</h3>
          <p class="opacity-80">如果你是一位开发者，Solar Network 为你准备了丰富的工具：原生语法高亮、代码片段分享功能，与你最喜欢的开发工具无缝集成。分享代码从未如此简单。</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-8 shadow-lg hover:shadow-xl">
          <div class="w-16 h-16 rounded-2xl bg-accent/20 flex items-center justify-center mb-4">
            <Zap class="w-8 h-8 text-accent" />
          </div>
          <h3 class="text-xl font-bold mb-2">开放生态</h3>
          <p class="opacity-80">我们提供完全文档化的 API，透明的接口限制和风险控制。无论是构建自己的客户端还是开发第三方应用，Solar Network 都是理想的起点。</p>
        </div>
      </div>
    </section>

    <section class="mb-20">
      <div class="text-center mb-12">
        <span class="badge badge-secondary badge-outline mb-4">功能特性</span>
        <h2 class="text-4xl font-bold mb-4">强大的功能体验</h2>
        <p class="text-lg opacity-70 max-w-2xl mx-auto">
          从日常社交到兴趣社区，Solian 为你提供完整的社交体验。
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <MessageSquare class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">时间线</h3>
          </div>
          <p class="opacity-80 text-sm">按时间顺序展示动态，不错过每一个精彩时刻。你可以关注感兴趣的人，实时获取他们的最新动态。</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <FileText class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">帖子、文章与瞬间</h3>
          </div>
          <p class="opacity-80 text-sm">多种内容类型，满足不同场景的表达需求。短动态、长文章、瞬间故事，你想怎么表达都可以。</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <MessageSquare class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">即时通讯</h3>
          </div>
          <p class="opacity-80 text-sm">实时聊天，支持群组对话。与好友一对一私密交流，或创建群组与志同道合的人热烈讨论。</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Users class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">领域</h3>
          </div>
          <p class="opacity-80 text-sm">按共同兴趣组织的社区，发现同好。每个领域都是一个主题社区，让你可以找到志趣相投的朋友。</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Shield class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">OAuth 集成</h3>
          </div>
          <p class="opacity-80 text-sm">安全的第三方认证，轻松登录。支持多种登录方式，无需记忆繁琐的密码，保护你的账号安全。</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Bell class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">签到</h3>
          </div>
          <p class="opacity-80 text-sm">位置和状态分享。每天签到不仅能记录你的生活轨迹，还能发现附近的有趣的人和事。</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Calendar class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">倒计时</h3>
          </div>
          <p class="opacity-80 text-sm">追踪特殊日期和节日。设置重要日子的倒计时，不再错过任何一个值得纪念的时刻。</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Rss class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">RSS 阅读器</h3>
          </div>
          <p class="opacity-80 text-sm">订阅外部资讯源，聚合你关注的内容。在一个地方阅读所有你关心的博客、新闻和网站更新。</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Wallet class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">钱包</h3>
          </div>
          <p class="opacity-80 text-sm">积分交易系统。参与社区活动获取积分，用积分解锁更多有趣的功能和特权。</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Sticker class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">贴纸</h3>
          </div>
          <p class="opacity-80 text-sm">用自定义贴纸表达独特的自我。丰富的贴纸库让你的对话更加生动有趣。</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <FileText class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">富文本编辑器</h3>
          </div>
          <p class="opacity-80 text-sm">基于 Markdown，支持扩展语法。无论你是写长文还是简单记录，都能轻松驾驭。</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Image class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">文件管理</h3>
          </div>
          <p class="opacity-80 text-sm">上传和管理文件。图片、文档、音视频，所有你分享的内容都能妥善保存和管理。</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Users class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">社交功能</h3>
          </div>
          <p class="opacity-80 text-sm">好友列表和黑名单管理。关注你喜欢的人，屏蔽你不想看到的内容，完全掌控你的社交体验。</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Globe class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">联邦网络</h3>
          </div>
          <p class="opacity-80 text-sm">与其他联邦实例互动，连接更广阔的世界。加入 Fediverse，与 Mastodon、Pixel 等平台的用户交流。</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <CheckCircle class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">成就与进度</h3>
          </div>
          <p class="opacity-80 text-sm">记录你在 Solar Network 的一点一滴。解锁各种成就，见证自己的成长轨迹。</p>
        </div>
      </div>
    </section>

    <section class="mb-16">
      <div class="card bg-gradient-to-r from-primary/20 via-secondary/20 to-accent/20 p-12 rounded-3xl">
        <div class="text-center">
          <h2 class="text-4xl font-bold mb-4">开始你的旅程</h2>
          <p class="text-xl opacity-80 mb-8">随时随地访问 Solar Network</p>
          
          <div class="flex flex-wrap justify-center gap-6 mb-8">
            <div class="flex items-center gap-2 bg-base-100/50 px-4 py-2 rounded-full">
              <Smartphone class="w-5 h-5 text-primary" />
              <span class="font-medium">iOS</span>
            </div>
            <div class="flex items-center gap-2 bg-base-100/50 px-4 py-2 rounded-full">
              <Smartphone class="w-5 h-5 text-primary" />
              <span class="font-medium">Android</span>
            </div>
            <div class="flex items-center gap-2 bg-base-100/50 px-4 py-2 rounded-full">
              <Monitor class="w-5 h-5 text-primary" />
              <span class="font-medium">macOS</span>
            </div>
            <div class="flex items-center gap-2 bg-base-100/50 px-4 py-2 rounded-full">
              <Monitor class="w-5 h-5 text-primary" />
              <span class="font-medium">Windows</span>
            </div>
            <div class="flex items-center gap-2 bg-base-100/50 px-4 py-2 rounded-full">
              <Monitor class="w-5 h-5 text-primary" />
              <span class="font-medium">Linux</span>
            </div>
          </div>
          
          <div class="flex flex-wrap justify-center gap-4">
            <a href="https://web.solian.app" target="_blank" class="btn btn-primary btn-lg rounded-full hover:scale-105 transition-transform">
              <ExternalLink class="w-5 h-5" />
              在浏览器中打开
            </a>
            <a href="https://github.com/Solsynth/Solian" target="_blank" class="btn btn-outline btn-lg rounded-full hover:scale-105 transition-transform">
              <Github class="w-5 h-5" />
              在 GitHub 上查看
            </a>
          </div>
        </div>
      </div>
    </section>

    <section>
      <div class="card bg-base-200 p-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div>
            <h2 class="text-3xl font-bold mb-2">需要帮助？</h2>
            <p class="text-lg opacity-80">欢迎在 GitHub 上报告 Bug 或联系我们。</p>
          </div>
          <div class="flex gap-4">
            <a href="https://github.com/Solsynth/Solian/issues" target="_blank" class="btn btn-outline btn-lg hover:scale-105 transition-transform">
              <Bug class="w-5 h-5" />
              报告问题
            </a>
            <a href="https://github.com/Solsynth/Solian/discussions" target="_blank" class="btn btn-ghost btn-lg hover:scale-105 transition-transform">
              <MessageSquare class="w-5 h-5" />
              提出建议
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
