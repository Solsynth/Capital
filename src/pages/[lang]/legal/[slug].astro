---
import Layout from '~/layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { ArrowLeft, Calendar } from 'lucide-astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, languages, type Lang } from '~/i18n/utils';

export const prerender = false;

export function getStaticPaths() {
  return [
    { params: { lang: 'en', slug: 'user-agreement' } },
    { params: { lang: 'en', slug: 'privacy-policy' } },
    { params: { lang: 'en', slug: 'refund-policy' } },
    { params: { lang: 'en', slug: 'solar-network-dev' } },
    { params: { lang: 'zh', slug: 'user-agreement' } },
    { params: { lang: 'zh', slug: 'privacy-policy' } },
    { params: { lang: 'zh', slug: 'refund-policy' } },
    { params: { lang: 'zh', slug: 'solar-network-dev' } },
  ];
}

const { lang: rawLang, slug } = Astro.params as { lang: Lang; slug: string };
const lang = rawLang as Lang;

// Validate language, redirect to detected language if invalid
if (!(lang in languages)) {
  const acceptLang = Astro.request.headers.get('accept-language');
  const preferredLang = acceptLang?.split(',')[0]?.split('-')[0];
  const targetLang = preferredLang === 'zh' ? 'zh' : 'en';
  return Astro.redirect(`/${targetLang}/${rawLang}/${slug}`);
}

const t = useTranslations(lang);

const allLegal = await getCollection('legal');

function getSlug(filename: string): string {
  return filename.replace(/^(en|zh)\//, '').replace(/\.md$/, '');
}

const page = allLegal.find(p => getSlug(p.id) === slug && p.id.startsWith(`${lang}/`));

if (!page) {
  return Astro.redirect(getRelativeLocaleUrl(lang, 'legal'));
}

const { Content } = await render(page);
---

<Layout title={page.data.title} description={page.data.description || 'Important legal document from Solsynth.'} lang={lang}>
  <div class="container mx-auto px-8 py-16 max-w-4xl">
    <div class="mb-8 -mx-4">
      <a href={getRelativeLocaleUrl(lang, 'legal')} class="btn btn-ghost btn-sm gap-1">
        <ArrowLeft class="w-4 h-4" />
        {t('legal.backToLegal')}
      </a>
    </div>

    <article>
      <header class="mb-8">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">{page.data.title}</h1>
        {page.data.updatedDate && (
          <div class="flex items-center gap-2 text-sm opacity-70">
            <Calendar class="w-4 h-4" />
            <span>{lang === 'zh' ? t('legal.lastUpdatedZh') : t('legal.lastUpdated')} {page.data.updatedDate}</span>
          </div>
        )}
        {page.data.description && (
          <p class="text-lg opacity-70 mt-4">{page.data.description}</p>
        )}
      </header>

      <div class="divider"></div>

      <div class="prose prose-lg max-w-none">
        <Content />
      </div>
    </article>
  </div>
</Layout>
