---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { FileText, Globe, Scale, Shield, Code } from 'lucide-astro';
import { getLangFromUrl, useTranslations, type Lang } from '../../../i18n/utils';

export const prerender = false;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const prefix = lang === 'zh' ? '/zh' : '';

const allLegal = await getCollection('legal');

function getSlug(filename: string): string {
  return filename.replace(/^(en|zh)\//, '').replace(/\.md$/, '');
}

const pageMap = new Map<string, typeof allLegal>();
for (const page of allLegal) {
  const slug = getSlug(page.id);
  if (!pageMap.has(slug)) {
    pageMap.set(slug, []);
  }
  pageMap.get(slug)!.push(page);
}

const currentLangPages = allLegal.filter(p => p.id.startsWith(`${lang}/`));
---

<Layout title={t('legal.title')} description={t('seo.legal.description')} lang={lang}>
  <div class="container mx-auto px-4 py-16 max-w-4xl">
    <div class="text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">{t('legal.title')}</h1>
      <p class="text-xl opacity-70">
        {t('legal.subtitle')}
      </p>
    </div>

    <div class="space-y-4">
      {currentLangPages.map(page => {
        const slug = getSlug(page.id);
        const icon = slug.includes('privacy') ? Shield : slug.includes('user') ? Scale : slug.includes('refund') ? FileText : Code;
        return (
          <a href={`${prefix}/legal/${slug}`} class="card bg-base-200 p-6 hover:shadow-lg transition-all duration-300 block group">
            <div class="flex items-start gap-4">
              <div class="p-3 bg-primary/10 rounded-lg group-hover:bg-primary/20 transition-colors">
                <icon class="w-6 h-6 text-primary" />
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-bold group-hover:text-primary transition-colors">{page.data.title}</h3>
                <p class="text-sm opacity-70 mt-1">{page.data.description}</p>
                {page.data.updatedDate && (
                  <p class="text-xs opacity-50 mt-2">
                    {lang === 'zh' ? t('legal.lastUpdatedZh') : t('legal.lastUpdated')} {page.data.updatedDate}
                  </p>
                )}
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
