---
import Layout from '../../layouts/Layout.astro';
import { Github, ExternalLink, Bug, ArrowLeft, Tag, Folder, MessageSquare, FileText, Rss, Users, CreditCard, Globe, Sticker, Code, Heart, Sparkles, Zap, Shield, Smartphone, Monitor, Bell, Calendar, Wallet, Image, CheckCircle } from 'lucide-astro';
---

<Layout title="Solar Network" description="A serene social network that makes self-expression and connecting with others simple and pure.">
  <div class="relative h-[60vh] min-h-120 overflow-hidden">
    <img src="/solar-network/screenshot.png" class="w-full h-full object-cover" alt="Solar Network" />
    <div class="absolute inset-0 bg-gradient-to-t from-base-100 via-base-100/60 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary/20 via-transparent to-secondary/20"></div>
    
    <div class="absolute bottom-0 left-0 right-0 p-8">
      <div class="container mx-auto flex flex-col md:flex-row items-end gap-6">
        <img src="/solar-network/icon.png" class="w-28 h-28 rounded-2xl shadow-2xl" alt="Solar Network" />
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-2">
            <h1 class="text-4xl md:text-4xl font-bold">Solar Network</h1>
          </div>
          <p class="text-xl opacity-90 mb-4">A serene social network that makes self-expression and connecting with others simple and pure.</p>
          <div class="flex flex-wrap gap-2 mt-3">
            <a href="/products?series=Solar%20Network" class="badge badge-primary badge-sm">
              <Folder class="w-3 h-3 mr-1" />
              Solar Network
            </a>
            <a href="/products?tag=Social%20Network" class="badge badge-outline badge-sm hover:badge-primary transition-colors">
              <Tag class="w-3 h-3 mr-1" />
              Social Network
            </a>
            <a href="/products?tag=Community" class="badge badge-outline badge-sm hover:badge-primary transition-colors">
              <Tag class="w-3 h-3 mr-1" />
              Community
            </a>
            <a href="/products?tag=ACG" class="badge badge-outline badge-sm hover:badge-primary transition-colors">
              <Tag class="w-3 h-3 mr-1" />
              ACG
            </a>
            <span class="badge badge-outline badge-sm">
              <Globe class="w-3 h-3 mr-1" />
              Fediverse
            </span>
          </div>
        </div>
        <div class="flex gap-3 flex-wrap">
          <a href="https://web.solian.app" target="_blank" class="btn btn-primary btn-lg rounded-full hover:scale-105 transition-transform">
            <Sparkles class="w-5 h-5" />
            Get Started
          </a>
          <a href="https://github.com/Solsynth/Solian" target="_blank" class="btn btn-outline btn-lg rounded-full hover:scale-105 transition-transform">
            <Github class="w-5 h-5" />
            GitHub
          </a>
        </div>
      </div>
    </div>
    
    <div class="absolute top-20 left-10 opacity-20">
      <Sparkles class="w-16 h-16 text-primary" />
    </div>
    <div class="absolute top-40 right-20 opacity-20">
      <Heart class="w-12 h-12 text-secondary" />
    </div>
  </div>

  <div class="container mx-auto px-4 py-16">
    <section class="mb-20">
      <div class="text-center mb-12">
        <span class="badge badge-primary badge-outline mb-4">About</span>
        <h2 class="text-4xl font-bold mb-4">About Solar Network</h2>
        <p class="text-lg opacity-70 max-w-3xl mx-auto">
          Solian (aka Solar Network) is a social platform designed to help you freely express yourself and connect with others. We don't intend to replace any mainstream platforms—just offer you another serene and harmonious community choice.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-8 shadow-lg hover:shadow-xl">
          <div class="w-16 h-16 rounded-2xl bg-primary/20 flex items-center justify-center mb-4">
            <Heart class="w-8 h-8 text-primary" />
          </div>
          <h3 class="text-xl font-bold mb-2">Serene & Harmonious</h3>
          <p class="opacity-80">A social space away from the noise, letting you focus on what truly matters—connecting with like-minded people. Share your life quietly without worrying about clutter and information overload.</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-8 shadow-lg hover:shadow-xl">
          <div class="w-16 h-16 rounded-2xl bg-secondary/20 flex items-center justify-center mb-4">
            <Code class="w-8 h-8 text-secondary" />
          </div>
          <h3 class="text-xl font-bold mb-2">Developer Friendly</h3>
          <p class="opacity-80">If you're a developer, Solar Network has rich tools for you: native syntax highlighting, code snippet sharing, and seamless integration with your favorite dev tools. Sharing code has never been easier.</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-8 shadow-lg hover:shadow-xl">
          <div class="w-16 h-16 rounded-2xl bg-accent/20 flex items-center justify-center mb-4">
            <Zap class="w-8 h-8 text-accent" />
          </div>
          <h3 class="text-xl font-bold mb-2">Open Ecosystem</h3>
          <p class="opacity-80">We provide fully documented APIs with transparent rate limits and risk controls. Whether building your own client or developing third-party apps, Solar Network is the perfect starting point.</p>
        </div>
      </div>
    </section>

    <section class="mb-20">
      <div class="text-center mb-12">
        <span class="badge badge-secondary badge-outline mb-4">Features</span>
        <h2 class="text-4xl font-bold mb-4">Powerful Features</h2>
        <p class="text-lg opacity-70 max-w-2xl mx-auto">
          From daily social interaction to interest-based communities, Solian provides a complete social experience.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <MessageSquare class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">Timeline</h3>
          </div>
          <p class="opacity-80 text-sm">Posts displayed chronologically, never miss a moment. Follow people you're interested in and get their latest updates in real time.</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <FileText class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">Posts, Articles & Moments</h3>
          </div>
          <p class="opacity-80 text-sm">Multiple content types for different scenarios. Short updates, long articles, moment stories—express yourself however you want.</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <MessageSquare class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">Instant Messaging</h3>
          </div>
          <p class="opacity-80 text-sm">Real-time chat with group support. Private conversations with friends or create groups for lively discussions with like-minded people.</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Users class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">Realms</h3>
          </div>
          <p class="opacity-80 text-sm">Interest-based communities for discovering kindred spirits. Each realm is a themed community where you can find friends with shared interests.</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Shield class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">OAuth Integration</h3>
          </div>
          <p class="opacity-80 text-sm">Secure third-party authentication for easy login. Support for multiple login methods without memorizing complex passwords.</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Bell class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">Check-ins</h3>
          </div>
          <p class="opacity-80 text-sm">Location and status sharing. Daily check-ins not only record your life journey but also help you discover interesting people and things nearby.</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Calendar class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">Countdown</h3>
          </div>
          <p class="opacity-80 text-sm">Track special dates and holidays. Set countdowns for important days so you never miss a memorable moment.</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Rss class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">RSS Reader</h3>
          </div>
          <p class="opacity-80 text-sm">Subscribe to external feeds and aggregate content you care about. Read all your favorite blogs, news, and website updates in one place.</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Wallet class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">Wallet</h3>
          </div>
          <p class="opacity-80 text-sm">Point trading system. Earn points by participating in community activities and unlock more fun features and privileges.</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Sticker class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">Stickers</h3>
          </div>
          <p class="opacity-80 text-sm">Express yourself with custom stickers. A rich sticker library makes your conversations more vivid and interesting.</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <FileText class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">Rich Text Editor</h3>
          </div>
          <p class="opacity-80 text-sm">Markdown-based with extended syntax support. Whether writing long articles or simple notes, you can handle it with ease.</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Image class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">File Management</h3>
          </div>
          <p class="opacity-80 text-sm">Upload and manage files. Images, documents, audio/video—all your shared content is safely stored and managed.</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Users class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">Social Features</h3>
          </div>
          <p class="opacity-80 text-sm">Friends list and blocklist management. Follow people you like, block content you don't want to see—fully control your social experience.</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <Globe class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">Fediverse</h3>
          </div>
          <p class="opacity-80 text-sm">Interact with other fediverse instances and connect to a broader world. Join the Fediverse and communicate with users from Mastodon, Pixel, and more.</p>
        </div>
        <div class="card bg-base-200 hover:bg-base-300 transition-all duration-300 hover:-translate-y-2 p-6 group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-primary/20 flex items-center justify-center group-hover:scale-110 transition-transform">
              <CheckCircle class="w-6 h-6 text-primary" />
            </div>
            <h3 class="text-lg font-bold text-primary">Achievements & Progress</h3>
          </div>
          <p class="opacity-80 text-sm">Record your journey on Solar Network. Unlock various achievements and witness your growth.</p>
        </div>
      </div>
    </section>

    <section class="mb-16">
      <div class="card bg-gradient-to-r from-primary/20 via-secondary/20 to-accent/20 p-12 rounded-3xl">
        <div class="text-center">
          <h2 class="text-4xl font-bold mb-4">Start Your Journey</h2>
          <p class="text-xl opacity-80 mb-8">Access Solar Network anytime, anywhere</p>
          
          <div class="flex flex-wrap justify-center gap-6 mb-8">
            <div class="flex items-center gap-2 bg-base-100/50 px-4 py-2 rounded-full">
              <Smartphone class="w-5 h-5 text-primary" />
              <span class="font-medium">iOS</span>
            </div>
            <div class="flex items-center gap-2 bg-base-100/50 px-4 py-2 rounded-full">
              <Smartphone class="w-5 h-5 text-primary" />
              <span class="font-medium">Android</span>
            </div>
            <div class="flex items-center gap-2 bg-base-100/50 px-4 py-2 rounded-full">
              <Monitor class="w-5 h-5 text-primary" />
              <span class="font-medium">macOS</span>
            </div>
            <div class="flex items-center gap-2 bg-base-100/50 px-4 py-2 rounded-full">
              <Monitor class="w-5 h-5 text-primary" />
              <span class="font-medium">Windows</span>
            </div>
            <div class="flex items-center gap-2 bg-base-100/50 px-4 py-2 rounded-full">
              <Monitor class="w-5 h-5 text-primary" />
              <span class="font-medium">Linux</span>
            </div>
          </div>
          
          <div class="flex flex-wrap justify-center gap-4">
            <a href="https://web.solian.app" target="_blank" class="btn btn-primary btn-lg rounded-full hover:scale-105 transition-transform">
              <ExternalLink class="w-5 h-5" />
              Open in Browser
            </a>
            <a href="https://github.com/Solsynth/Solian" target="_blank" class="btn btn-outline btn-lg rounded-full hover:scale-105 transition-transform">
              <Github class="w-5 h-5" />
              View on GitHub
            </a>
          </div>
        </div>
      </div>
    </section>

    <section>
      <div class="card bg-base-200 p-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div>
            <h2 class="text-3xl font-bold mb-2">Need Help?</h2>
            <p class="text-lg opacity-80">Feel free to report bugs on GitHub or contact us.</p>
          </div>
          <div class="flex gap-4">
            <a href="https://github.com/Solsynth/Solian/issues" target="_blank" class="btn btn-outline btn-lg hover:scale-105 transition-transform">
              <Bug class="w-5 h-5" />
              Report Issue
            </a>
            <a href="https://github.com/Solsynth/Solian/discussions" target="_blank" class="btn btn-ghost btn-lg hover:scale-105 transition-transform">
              <MessageSquare class="w-5 h-5" />
              Suggest Feature
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>
