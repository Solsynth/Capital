---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import StatsSection from '../components/StatsSection.astro';
import ProductsSection from '../components/ProductsSection.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import UpdatesSection from '../components/UpdatesSection.astro';
import { getCollection } from 'astro:content';

const products = await getCollection('products');
---

<Layout title="We are Solsynth">
  <Hero />
  <StatsSection />
  <ProductsSection products={products} />
  <FeaturesSection />
  <UpdatesSection />
</Layout>
