---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { ArrowLeft, Calendar } from 'lucide-astro';

export const prerender = false;

const { slug } = Astro.params;

const allLegal = await getCollection('legal');

function getSlug(filename: string): string {
  return filename.replace(/^(en|zh)\//, '').replace(/\.md$/, '');
}

const page = allLegal.find(p => getSlug(p.id) === slug && p.id.startsWith('en/'));

if (!page) {
  return Astro.redirect('/legal');
}

const { Content } = await render(page);
---

<Layout
  title={page.data.title}
  description={page.data.description || 'Important legal document from Solsynth.'}
>
  <div class="container mx-auto px-4 py-16 max-w-4xl">
    <div class="mb-8">
      <a href="/legal" class="btn btn-ghost btn-sm gap-1">
        <ArrowLeft class="w-4 h-4" />
        Back to Legal
      </a>
    </div>

    <article>
      <header class="mb-8">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">{page.data.title}</h1>
        {page.data.updatedDate && (
          <div class="flex items-center gap-2 text-sm opacity-70">
            <Calendar class="w-4 h-4" />
            <span>Last updated: {page.data.updatedDate}</span>
          </div>
        )}
        {page.data.description && (
          <p class="text-lg opacity-70 mt-4">{page.data.description}</p>
        )}
      </header>

      <div class="divider"></div>

      <div class="prose prose-lg max-w-none">
        <Content />
      </div>
    </article>
  </div>
</Layout>
